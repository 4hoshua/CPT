# Copy to .env and adjust before running `docker compose up`.

# JWT signing secret — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite database path inside the backend container (persisted in a volume).
DATABASE_URL=sqlite:////data/app.db

# Initial admin, seeded on first startup only (when no users exist).
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin

# Allowed CORS origins (only relevant when developing against the Vite dev server).
CORS_ORIGINS=http://localhost:5173
